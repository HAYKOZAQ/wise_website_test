# Copy to backend/.env for LOCAL development only.
# NEVER commit real keys. On Render/Railway set these in the dashboard.

GEMINI_API_KEY=your_google_ai_studio_key_here

# Required for any admin/ingest endpoint outside localhost.
# If unset, admin endpoints are only reachable from the server's loopback interface.
ADMIN_TOKEN=your_strong_random_token_here

# Optional
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma2
# GEMINI_GENERATE_MODELS=gemini-2.5-flash,gemini-flash-latest

# Own local embedding backend (no Google/Ollama embed calls)
# USE_LOCAL_EMBEDDER=1
# LOCAL_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# LOCAL_EMBED_DEVICE=cpu

# Hybrid retrieval + re-ranking
# USE_RERANKER=0
# HYBRID_SEMANTIC_WEIGHT=0.6
# QUERY_EXPANSION=0
# RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# Security / network
# Number of trusted proxy hops in front of the API. Unset (0) means the socket
# peer is used directly; never set this unless you are behind a trusted LB.
# TRUST_PROXY_HOPS=0
# Comma-separated absolute paths admin import endpoints may read PDFs from.
# The bundled backend/pdfs is always allowed.
# WISEF_IMPORT_ROOTS=C:\Drop\PDFs,/mnt/shared-pdfs
