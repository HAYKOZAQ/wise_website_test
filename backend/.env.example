# Copy to backend/.env for LOCAL development only.
# NEVER commit real keys. On Render/Railway set these in the dashboard.

GEMINI_API_KEY=your_google_ai_studio_key_here

# Optional
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma2
# GEMINI_GENERATE_MODELS=gemini-2.5-flash,gemini-flash-latest

# Own local embedding backend (no Google/Ollama embed calls)
# USE_LOCAL_EMBEDDER=1
# LOCAL_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# LOCAL_EMBED_DEVICE=cpu
